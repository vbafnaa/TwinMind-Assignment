# Copy to .env.production (do not commit) or set in CI / Netlify / Vercel "Build" env.
# Public API base URL — no trailing slash. Leave empty only if the SPA is served
# behind the same host as /api (reverse proxy, Option B in root README).
#
# Example:
# REACT_APP_API_URL=https://twinmind-api.onrender.com
REACT_APP_API_URL=
